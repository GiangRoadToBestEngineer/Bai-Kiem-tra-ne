        cout << "3. Khoi tao ma tran A, B, C va tinh tong D = A+B+C\n";
        cout << "4. Xuat duong cheo ma tran D va sap xep giam dan\n";
        cout << "5. Thoat\n";
        cout << "========================================\n";
        cout << "Nhap lua chon (1-5): ";
        cin >> luaChon;

        switch (luaChon) {
            case 1:
                giaiPhuongTrinhTrungPhuong();
                break;
            case 2:
                tinhHinhThoi();
                break;
            case 3:
                xuLyMaTran(n, m, D);
                break;
            case 4:
                xuatDuongCheo(n, m, D);
                break;
            case 5:
                cout << "Chuong trinh ket thuc.\n";
