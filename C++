            default:
                cout << "Lua chon khong hop le. Vui long chon lai tu 1 den 5.\n";
                break;
        }

        // Yêu cầu: Hiện câu hỏi làm nữa không
        cout << "\nBan co muon lam nua khong (Y/N)? Nhan Y/y de tiep tuc: ";
        cin >> tiepTuc;

    } while (tiepTuc == 'Y' || tiepTuc == 'y');

    cout << "Chuong trinh ket thuc. Tam biet!\n";
    return 0;
}
