    int luaChon;
    char tiepTuc;
    
    // Khai báo chung cho D để có thể truyền từ Cụm 3 sang Cụm 4
    int n = 0, m = 0;
    vector<vector<int>> D;

    do {
        // Hiển thị Menu
        cout << "\n================= MENU =================\n";
        cout << "1. Giai phuong trinh trung phuong AX^4 + BX^2 + C = 0\n";
